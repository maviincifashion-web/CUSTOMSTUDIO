{
  "expo": {
    "name": "MaviinciApp",
    "slug": "MaviinciApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maviinciapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.MaviinciApp",
      "tv": {
        "enabled": false,
        "banner": "./assets/images/tv-banner.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "firebase": {
        "apiKey": "AIzaSyDIuRhzgQs1D8nAVkV_V3GJvCsLDzIbDQc",
        "authDomain": "maviinvi.firebaseapp.com",
        "projectId": "maviinvi",
        "storageBucket": "maviinvi.appspot.com",
        "messagingSenderId": "156367186367",
        "appId": "1:156367186367:web:9170179cdb5e641972990a",
        "databaseURL": "https://maviinvi-default-rtdb.asia-southeast1.firebasedatabase.app"
      },
      "router": {},
      "eas": {
        "projectId": "cefeb7ca-e1f9-40f1-8f3b-dd029ae5ae3c"
      }
    }
  }
}